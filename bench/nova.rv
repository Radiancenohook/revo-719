print("a perfect number equals the sum of its proper divisors; N = 20000\n")

let start = time.now()
let found: int = 0

for num in 0..20001 do
    let sum: int = 0
    for j in 1..num do
        if num % j == 0
            sum += j
    end

    if num == sum do
        found += 1
        print!("found %v (%vth perfect number)", num, found)
    end
end

print!("found %v perfect numbers", found)
print!("took %v", (time.now() - start)/1000)
